@page "/"
@rendermode InteractiveServer

<PageTitle>PINDI KI KHOJ</PageTitle>

<div id="splash-screen">
    <div class="splash-overlay-glow"></div>
    <div class="splash-content">
        <div class="splash-logo-container mb-4 d-flex justify-content-center align-items-center position-relative">
            <div class="splash-pulse-circle"></div>
            <img src="/images/logo.png" alt="Pindi Ki Khoj Logo" style="max-width: 250px; z-index: 2;" class="animate-bounce hollow-center-img" />
        </div>
        <h1 class="splash-title">PINDI KI KHOJ</h1>
        <p class="splash-subtitle mt-2 mb-5">Rawalpindi's Premium Local Service & Business Finder</p>
        <button class="btn btn-gradient btn-lg rounded-pill px-5 py-3 shadow-lg fs-5 animate-pulse-btn" onclick="window.pindi.fadeOutSplash()">
            <i class="bi bi-search me-2"></i> Dhundho Jo Dhundhna
        </button>
    </div>
</div>

<div class="landing position-relative overflow-hidden">
    <!-- Background Watermark Logo -->
    <div class="position-absolute top-50 start-50 translate-middle" style="z-index: 0; pointer-events: none; opacity: 0.3;">
        <img src="/images/logo.png" class="hollow-center-img" style="width: 150vw; max-width: 1000px;" alt="" />
    </div>
    <nav class="landing-nav position-absolute w-100 z-3">
        <div class="container d-flex justify-content-between align-items-center py-4">
            <div class="logo fs-4 fw-bolder text-white text-shadow-sm d-flex align-items-center">
                <img src="/images/logo.png" alt="Logo" style="height: 40px; margin-right: 10px;" /> PINDI KI KHOJ
            </div>
            <div class="d-flex gap-3">
                <a href="/account/login" class="btn btn-outline-light rounded-pill px-4 py-2 fw-bold">Sign In</a>
                <a href="/account/register" class="btn btn-gradient rounded-pill px-4 py-2">Get Started</a>
            </div>
        </div>
    </nav>

    <section class="hero d-flex align-items-center position-relative overflow-hidden pb-2" style="padding-top: 9rem;">
        <!-- Abstract Background Elements -->
        <div class="position-absolute top-0 end-0 translate-middle p-5 bg-accent opacity-25 rounded-circle blur-3xl" style="width: 40vw; height: 40vw; filter: blur(100px);"></div>
        <div class="position-absolute bottom-0 start-0 translate-middle p-5 bg-primary opacity-25 rounded-circle blur-3xl" style="width: 50vw; height: 50vw; filter: blur(120px);"></div>

        <div class="container text-center position-relative z-2">
            <div class="mb-4 d-flex justify-content-center">
                <img src="/images/logo.png" alt="Pindi Ki Khoj Logo" style="max-width: 150px;" class="d-block d-md-none mb-3 hollow-center-img" />
            </div>
            <h1 class="display-3 fw-900 text-white mb-4 text-shadow-lg" style="letter-spacing: -1px;">
                Discover Pindi's finest <br />
                <span class="text-accent position-relative d-inline-block">
                    local professionals
                    <svg class="position-absolute w-100 h-100 start-0 bottom-0 translate-middle-y mt-2" style="z-index:-1; opacity:0.3" viewBox="0 0 200 20" preserveAspectRatio="none"><path d="M0,10 Q100,20 200,10" stroke="var(--accent)" stroke-width="8" fill="none"/></svg>
                </span>
            </h1>
            <p class="lead text-white-100 fs-4 max-w-3xl mx-auto mb-5">
                From expert mechanics to trusted home tutors or certified restauraunts. Chat directly, negotiate fairly, and track live on the map.
            </p>
            <div class="hero-actions d-flex flex-column flex-sm-row justify-content-center gap-4">
                <a href="/account/register?role=User" class="btn btn-gradient btn-lg rounded-pill px-5 py-3 shadow-lg hover-elevate">
                    <i class="bi bi-search me-2"></i> I need a service
                </a>
                <a href="/account/register?role=BusinessOwner" class="btn btn-outline-light btn-lg rounded-pill px-5 py-3 shadow-lg hover-elevate glass-panel-hover">
                    <i class="bi bi-shop me-2"></i> I own a business
                </a>
            </div>
        </div>
    </section>

    <section class="features container pt-4 pb-5">
        @* Demo credentials removed *@
        <div class="row g-5">
            <div class="col-md-4">
                <div class="landing-feature-card p-5 h-100 text-center shadow-sm">
                    <div class="icon-box bg-accent-soft text-accent rounded-circle d-inline-flex align-items-center justify-content-center mb-4 icon-glow-accent" style="width: 80px; height: 80px; background: rgba(0,200,83,0.15);">
                        <i class="bi bi-radar fs-1"></i>
                    </div>
                    <h4 class="mb-3">Hyper-local Search</h4>
                    <p class="mb-0">Discover verified businesses right in your neighborhood. Pindi's best at your fingertips.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="landing-feature-card p-5 h-100 text-center shadow-sm">
                    <div class="icon-box bg-primary-soft text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-4 icon-glow-primary" style="width: 80px; height: 80px; background: rgba(13,110,253,0.15);">
                        <i class="bi bi-chat-dots fs-1"></i>
                    </div>
                    <h4 class="mb-3">Direct Negotiation</h4>
                    <p class="mb-0">Chat instantly, discuss your needs, and agree on a fair price before committing.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="landing-feature-card p-5 h-100 text-center shadow-sm">
                    <div class="icon-box bg-warning-soft text-warning rounded-circle d-inline-flex align-items-center justify-content-center mb-4 icon-glow-warning" style="width: 80px; height: 80px; background: rgba(255,193,7,0.15);">
                        <i class="bi bi-geo-fill fs-1"></i>
                    </div>
                    <h4 class="mb-3">Live Map Tracking</h4>
                    <p class="mb-0">Real-time GPS tracking. Whether you visit them or they come to you, never lose sight.</p>
                </div>
            </div>
        </div>
    </section>
</div>
