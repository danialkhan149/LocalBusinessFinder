@page "/user/requests"
@layout UserLayout
@attribute [Authorize(Roles = AppRoles.User)]
@rendermode InteractiveServer
@inject RequestService RequestService
@inject AuthenticationStateProvider AuthState

<PageTitle>My Requests - Pindi Ki Khoj</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1 text-dark">My Service Requests</h1>
            <p class="text-muted mb-0">Track active bookings, check historical engagement, and chat with service providers</p>
        </div>
    </div>

    <div class="row g-3">
        @foreach (var r in _requests)
        {
            var badgeColor = r.Status switch
            {
                RequestStatus.Pending => "bg-warning text-dark",
                RequestStatus.Accepted => "bg-primary",
                RequestStatus.DealAgreed => "bg-info text-white",
                RequestStatus.InProgress => "bg-secondary text-white",
                RequestStatus.Completed => "bg-success",
                _ => "bg-light text-muted"
            };
            <div class="col-md-6 col-lg-4">
                <div class="premium-card p-4 border-0 shadow-sm hover-elevate bg-white h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge @badgeColor rounded-pill px-3 py-2 small">@r.Status</span>
                            <span class="text-muted small"><i class="bi bi-clock me-1"></i> @r.CreatedAt.ToLocalTime().ToString("g")</span>
                        </div>
                        <h5 class="fw-bold text-dark mb-1 mt-2">@r.Title</h5>
                        <p class="text-muted small mb-3"><i class="bi bi-shop me-1"></i> @_requests.FirstOrDefault(req => req.Id == r.Id)?.Business?.Name</p>
                        <p class="text-muted fs-sm" style="line-height: 1.5; height: 3em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">@r.Description</p>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top border-light">
                        <span class="fw-bold text-dark fs-sm">
                            Rs @(r.Business?.HourlyRate.ToString("N0") ?? "0")
                            @if (r.AgreedPrice.HasValue)
                            {
                                <span class="text-success ms-1 small">(negotiated to Rs @r.AgreedPrice.Value.ToString("N0"))</span>
                            }
                            else
                            {
                                <span class="text-warning ms-1 small">(Negotiating)</span>
                            }
                        </span>
                        <a href="/request/@r.Id" class="btn btn-sm btn-gradient px-4 py-2">
                            <i class="bi bi-folder2-open me-1"></i> Open
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!_requests.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm my-4">
            <i class="bi bi-journal-x fs-1 text-muted mb-3 d-block"></i>
            <h5 class="fw-bold text-dark">No requests yet</h5>
            <p class="text-muted mb-4">You haven't requested any services. Start by looking for trusted professionals near you.</p>
            <a href="/user" class="btn btn-gradient rounded-pill px-5 py-3 shadow">
                <i class="bi bi-search me-2"></i> Find a Business
            </a>
        </div>
    }
</div>

@code {
    private List<ServiceRequest> _requests = [];

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (userId != null)
            _requests = await RequestService.GetForUserAsync(userId);
    }
}
