@page "/owner/requests"
@layout OwnerLayout
@attribute [Authorize(Roles = AppRoles.BusinessOwner)]
@rendermode InteractiveServer
@inject BusinessService BusinessService
@inject RequestService RequestService
@inject AuthenticationStateProvider AuthState

<PageTitle>Incoming Requests - Pindi Ki Khoj</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1 text-dark">Incoming Requests</h1>
            <p class="text-muted mb-0">Respond to customer requests and negotiate service details</p>
        </div>
    </div>

    @if (_business == null)
    {
        <div class="alert alert-info border-0 rounded-4 shadow-sm text-center py-4">
            <i class="bi bi-info-circle fs-2 text-info mb-2 d-block"></i>
            <h5 class="fw-bold">Register your business first</h5>
            <p class="text-muted mb-0">Please set up your business details to receive service request notifications.</p>
        </div>
    }
    else
    {
        @if (!_requests.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted mb-3 d-block"></i>
                <h5 class="fw-bold text-dark">No requests yet</h5>
                <p class="text-muted">You will see incoming jobs from customers here once they request your services.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var r in _requests)
                {
                    var badgeColor = r.Status switch
                    {
                        RequestStatus.Pending => "bg-warning text-dark",
                        RequestStatus.Accepted => "bg-primary",
                        RequestStatus.DealAgreed => "bg-info text-white",
                        RequestStatus.InProgress => "bg-secondary text-white",
                        RequestStatus.Completed => "bg-success",
                        _ => "bg-light text-muted"
                    };
                    <div class="col-md-6">
                        <div class="premium-card p-4 border-0 shadow-sm hover-elevate">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="fw-bold mb-1 text-dark">@r.Title</h5>
                                    <span class="badge @badgeColor rounded-pill px-3 py-2 small">@r.Status</span>
                                </div>
                                <div class="text-end text-muted small">
                                    <i class="bi bi-clock me-1"></i> @r.CreatedAt.ToLocalTime().ToString("g")
                                </div>
                            </div>
                            <p class="text-muted mb-3 fs-sm" style="line-height: 1.5; height: 4.5em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;">@r.Description</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="small fw-semibold text-dark">Customer:</span>
                                    <span class="text-muted small">@r.User?.FullName</span>
                                </div>
                                <a href="/request/@r.Id" class="btn btn-sm btn-gradient px-4 py-2">
                                    <i class="bi bi-chat-left-text me-1"></i> Manage
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private Business? _business;
    private List<ServiceRequest> _requests = [];

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (userId == null) return;

        _business = await BusinessService.GetByOwnerIdAsync(userId);
        if (_business != null)
        {
            var allRequests = await RequestService.GetForBusinessAsync(_business.Id);
            _requests = allRequests.Where(r => r.Status != RequestStatus.Completed && r.Status != RequestStatus.Cancelled).ToList();
        }
    }
}
