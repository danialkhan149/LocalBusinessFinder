@page "/admin/businesses"
@layout AdminLayout
@attribute [Authorize(Roles = AppRoles.Admin)]
@rendermode InteractiveServer
@inject BusinessService BusinessService
@inject AdminService AdminService

<PageTitle>Businesses - Pindi Ki Khoj</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1 text-dark">Business Approvals</h1>
            <p class="text-muted mb-0">Review pending business registrations and oversee registered partners</p>
        </div>
    </div>

    @if (_pending.Any())
    {
        <h5 class="text-warning fw-bold mb-3 d-flex align-items-center">
            <i class="bi bi-hourglass-split me-2"></i> Pending Approvals (@_pending.Count)
        </h5>
        <div class="row g-3 mb-5">
            @foreach (var b in _pending)
            {
                <div class="col-md-6">
                    <div class="premium-card p-4 border-0 shadow-sm hover-elevate">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="fw-bold mb-1">@b.Name</h5>
                                <span class="badge rounded-pill bg-light text-dark px-3 py-2 small mb-2 border">@b.Category?.Name</span>
                                <div class="text-muted small mt-1"><i class="bi bi-geo-alt-fill me-1"></i> @b.Address</div>
                            </div>
                            <div class="text-end">
                                <div class="small fw-semibold text-dark">Owner</div>
                                <div class="text-muted small">@b.Owner?.FullName</div>
                                <div class="text-muted small">@b.Owner?.Email</div>
                            </div>
                        </div>
                        <hr class="text-muted opacity-25" />
                        <div class="d-flex justify-content-end gap-2">
                            <button class="btn btn-sm btn-gradient px-4 py-2" @onclick="() => Approve(b.Id)">
                                <i class="bi bi-check-lg me-1"></i> Approve
                            </button>
                            <button class="btn btn-sm btn-outline-danger rounded-pill px-4 py-2" @onclick="() => Reject(b.Id)">
                                <i class="bi bi-x-lg me-1"></i> Reject
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <h5 class="fw-bold text-dark mb-3 mt-4"><i class="bi bi-shop-window text-accent me-2"></i> All Registered Partners</h5>
    <div class="premium-card p-4 border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr class="text-uppercase text-muted fs-xs" style="letter-spacing: 0.5px;">
                        <th class="border-bottom py-3">Business Name</th>
                        <th class="border-bottom py-3">Category</th>
                        <th class="border-bottom py-3">Status</th>
                        <th class="border-bottom py-3 text-end">Rating</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in _all)
                    {
                        <tr>
                            <td class="py-3 fw-bold text-dark">@b.Name</td>
                            <td class="py-3"><span class="badge bg-light text-dark border px-3 py-2">@b.Category?.Name</span></td>
                            <td class="py-3">
                                @if (b.IsApproved)
                                {
                                    <span class="badge rounded-pill bg-success-soft text-success px-3 py-2 me-1" style="background: rgba(25, 135, 84, 0.1);"><i class="bi bi-patch-check-fill me-1"></i> Approved</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-warning-soft text-warning px-3 py-2 me-1" style="background: rgba(253, 126, 20, 0.1);"><i class="bi bi-clock me-1"></i> Pending</span>
                                }
                                @if (b.IsOnline)
                                {
                                    <span class="badge rounded-pill bg-info-soft text-info px-3 py-2" style="background: rgba(13, 202, 240, 0.1);"><i class="bi bi-circle-fill fs-2xs me-1"></i> Online</span>
                                }
                            </td>
                            <td class="py-3 text-end">
                                <span class="fw-bold text-warning"><i class="bi bi-star-fill me-1"></i> @b.Rating.ToString("F1")</span>
                                <span class="text-muted small">(@b.ReviewCount reviews)</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<Business> _pending = [];
    private List<Business> _all = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _pending = await BusinessService.GetPendingApprovalAsync();
        _all = await BusinessService.GetAllAsync();
    }

    private async Task Approve(int id)
    {
        await AdminService.ApproveBusinessAsync(id);
        await LoadAsync();
    }

    private async Task Reject(int id)
    {
        await AdminService.RejectBusinessAsync(id);
        await LoadAsync();
    }
}
